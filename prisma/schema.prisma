generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         String        @default("INVESTOR")
  image        String?
  balance      Float         @default(10000)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  farms        Farm[]
  investments  Investment[]
  transactions Transaction[]
}

model Farm {
  id           String       @id @default(cuid())
  name         String
  description  String
  location     String
  cropType     String
  totalPlots   Int
  soldPlots    Int          @default(0)
  pricePerPlot Float
  expectedROI  Float
  imageUrl     String
  status       String       @default("ACTIVE")
  farmerId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  farmer       User         @relation(fields: [farmerId], references: [id])
  investments  Investment[]
}

model Investment {
  id        String   @id @default(cuid())
  userId    String
  farmId    String
  plotCount Int
  amount    Float
  returns   Float    @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  farm      Farm     @relation(fields: [farmId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
